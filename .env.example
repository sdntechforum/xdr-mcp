# Cisco XDR MCP Server - Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env or put credentials in mcp.json.

# === Required: OAuth2 API Client Credentials ===
# Create an API Client in XDR: Administration > API Clients
# See: https://docs.xdr.security.cisco.com/Content/Administration/api-clients.htm
XDR_CLIENT_ID=your_client_id_here
XDR_CLIENT_PASSWORD=your_client_password_here

# === Optional: Region (default: us) ===
# us  = North America (xdr.us.security.cisco.com)
# eu  = Europe (xdr.eu.security.cisco.com)
# apjc = Asia Pacific, Japan, China (xdr.apjc.security.cisco.com)
XDR_REGION=us

# === Optional: Override API Base URLs (for custom/proxy environments) ===
# XDR_OAUTH_TOKEN_URL=https://visibility.amp.cisco.com/iroh/oauth2/token
# XDR_AUTOMATE_BASE_URL=https://automate.us.security.cisco.com/api
# XDR_PLATFORM_BASE_URL=https://visibility.amp.cisco.com/iroh
# XDR_PRIVATE_INTEL_BASE_URL=https://private.intel.amp.cisco.com/ctia
